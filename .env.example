# Firebase Emulator
VITE_USE_FUNCTIONS_EMULATOR=true
GOOGLE_CLOUD_PROJECT="your-project-id"
FIRESTORE_EMULATOR_HOST="127.0.0.1:8080"
VITE_FUNCTIONS_BASE_URL=http://127.0.0.1:5001/your-project-id/asia-southeast1

# Email Service (Optional)
SMTP_EMAIL=your-email@gmail.com
SMTP_PASS=your-app-password

# OTP Email Gateway (Optional - Apps Script Web App)
VITE_OTP_EMAIL_WEBAPP_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
VITE_OTP_EMAIL_API_KEY=your-api-key

# Cloudinary (for eKYC image upload)
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# EmailJS (for OTP emails)
VITE_EMAILJS_SERVICE_ID=your-service-id
VITE_EMAILJS_TEMPLATE_ID=your-template-id
VITE_EMAILJS_PUBLIC_KEY=your-public-key
